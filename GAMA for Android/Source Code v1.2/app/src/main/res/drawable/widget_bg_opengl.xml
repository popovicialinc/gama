<?xml version="1.0" encoding="utf-8"?>
<!-- Frosted dark card with a subtle green top-edge glow — OpenGL state -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base: dark translucent fill -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E6141418" />
            <corners android:radius="@dimen/widget_corner_radius_large" />
        </shape>
    </item>

    <!-- Subtle top-glow in green -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#333ECF8E"
                android:endColor="#00141418" />
            <corners android:radius="@dimen/widget_corner_radius_large" />
        </shape>
    </item>

    <!-- 1 dp border — green, low opacity -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#403ECF8E" />
            <corners android:radius="@dimen/widget_corner_radius_large" />
        </shape>
    </item>

</layer-list>
