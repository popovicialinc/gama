<?xml version="1.0" encoding="utf-8"?>
<!-- Frosted dark card — neutral/default state -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E6141418" />
            <corners android:radius="@dimen/widget_corner_radius_large" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#22FFFFFF"
                android:endColor="#00141418" />
            <corners android:radius="@dimen/widget_corner_radius_large" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#20FFFFFF" />
            <corners android:radius="@dimen/widget_corner_radius_large" />
        </shape>
    </item>

</layer-list>
