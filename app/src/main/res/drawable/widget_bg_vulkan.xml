<?xml version="1.0" encoding="utf-8"?>
<!-- Frosted dark card with a subtle purple top-edge glow — Vulkan state -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base: dark translucent fill (mimics frosted glass over wallpaper) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E6141418" />
            <corners android:radius="@dimen/widget_corner_radius_large" />
        </shape>
    </item>

    <!-- Subtle top-glow in purple -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#338A7FFF"
                android:endColor="#00141418" />
            <corners android:radius="@dimen/widget_corner_radius_large" />
        </shape>
    </item>

    <!-- 1 dp border — same purple, low opacity -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#408A7FFF" />
            <corners android:radius="@dimen/widget_corner_radius_large" />
        </shape>
    </item>

</layer-list>
