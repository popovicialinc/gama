<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- GAMA Widget corner radii ─ referenced via R.dimen.* in GamaWidget.kt
         and via @dimen/* inside the XML drawable files.               -->

    <!-- Outer card — matches Samsung One UI 8 widget radius (~28 dp) -->
    <dimen name="widget_corner_radius_large">28dp</dimen>

    <!-- Inner info card -->
    <dimen name="widget_corner_radius_medium">18dp</dimen>

    <!-- Pill buttons -->
    <dimen name="widget_corner_radius_pill">14dp</dimen>

    <!-- Chips / badges -->
    <dimen name="widget_corner_radius_small">8dp</dimen>

    <!-- Status dot (half of dot size = 4 dp for a 8 dp dot) -->
    <dimen name="widget_corner_radius_dot">4dp</dimen>
</resources>